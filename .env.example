# ============================================================
# DeepValue AI — Environment Configuration
# ============================================================
# To use: cp .env.example .env
# Then edit .env with your actual values.
# NEVER commit .env to Git (it's in .gitignore).
# ============================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# SimFin API key — register for free at https://app.simfin.com/
# Used by: python -m core.fundamental_database --source simfin
SIMFIN_API_KEY=your_api_key_here

# FRED API key — register for free at https://fred.stlouisfed.org/docs/api/api_key.html
# Used by: python -m core.macro_database
FRED_API_KEY=your_api_key_here