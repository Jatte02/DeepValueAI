# ============================================================
# Python
# ============================================================
# Compiled bytecode — Python generates these automatically.
__pycache__/
*.pyc
*.pyo

# Packaging
*.egg-info/
dist/
build/

# ============================================================
# Virtual environments
# ============================================================
# Contains ALL installed libraries (pandas, streamlit, etc.).
# Can weigh 500MB+. Each person recreates with: pip install -e ".[dev]"
.venv/
venv/
env/

# ============================================================
# Generated data
# ============================================================
# Large raw files that can be regenerated are excluded.
# Small Parquet feature files are tracked for Streamlit Cloud.
data/training_dataset.csv
data/drift_report.html
data/test_drift.html
data/ohlcv_cache/
data/fundamentals/simfin_cache/

# ============================================================
# Claude Code (local configuration)
# ============================================================
.claude/

# ============================================================
# Environment variables
# ============================================================
# Contains API keys, passwords, sensitive configuration.
# NEVER committed to Git. Only .env.example is tracked as a template.
.env

# ============================================================
# Streamlit secrets (API keys configured in Streamlit Cloud)
# ============================================================
.streamlit/secrets.toml

# ============================================================
# IDE and editors
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Operating system
# ============================================================
# macOS creates .DS_Store in every folder opened in Finder.
# Windows creates Thumbs.db for thumbnails.
.DS_Store
Thumbs.db

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# MLflow
# ============================================================
mlruns/

# ============================================================
# Testing and linting cache
# ============================================================
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
